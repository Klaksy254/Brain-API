# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Simulation settings (all have sensible defaults in config.py)
WQ_INSTRUMENT_TYPE=EQUITY
WQ_REGION=USA
WQ_UNIVERSE=TOP3000
WQ_DELAY=1
WQ_DECAY=15
WQ_NEUTRALIZATION=SUBINDUSTRY
WQ_TRUNCATION=0.08
WQ_PASTEURIZATION=ON
WQ_TEST_PERIOD=P1Y6M
WQ_UNIT_HANDLING=VERIFY
WQ_NAN_HANDLING=OFF
WQ_LANGUAGE=FASTEXPR

# Runner settings
WQ_BATCH_SIZE=8
WQ_QUOTA_FLOOR=50

# Paths
WQ_CACHE_PATH=simulation_cache.parquet
WQ_CREDENTIALS_PATH=~/.brain_credentials
WQ_RESULTS_DIR=results/
